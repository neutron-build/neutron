{
  "name": "@neutron/playground",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "neutron-ts dev",
    "build": "neutron-ts build",
    "build:vercel": "neutron-ts build --preset vercel",
    "build:cloudflare": "neutron-ts build --preset cloudflare --cloudflare-mode workers",
    "build:docker": "neutron-ts build --preset docker",
    "start": "neutron-ts start",
    "preview": "neutron-ts preview",
    "worker": "neutron-ts worker",
    "db:generate": "drizzle-kit generate --config drizzle.config.mjs",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.mjs",
    "db:seed": "node ./scripts/seed.mjs",
    "deploy-check:vercel": "neutron-ts deploy-check --preset vercel",
    "deploy-check:cloudflare": "neutron-ts deploy-check --preset cloudflare",
    "deploy-check:docker": "neutron-ts deploy-check --preset docker"
  },
  "dependencies": {
    "neutron": "workspace:*",
    "neutron-cli": "workspace:*",
    "neutron-data": "workspace:*",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.4",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
