  },
  "peerDependencies": {
    "ioredis": "^5.8.1"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.2"
  }
