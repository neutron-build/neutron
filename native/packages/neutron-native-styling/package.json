{
  "name": "@neutron/native-styling",
  "version": "0.1.0",
  "description": "NeutronWind — build-time className-to-StyleSheet transform for Neutron Native",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./babel": {
      "import": "./dist/babel-plugin.js",
      "require": "./dist/babel-plugin.cjs",
      "types": "./dist/babel-plugin.d.ts"
    },
    "./rspack": {
      "import": "./dist/rspack-loader.js",
      "require": "./dist/rspack-loader.cjs",
      "types": "./dist/rspack-loader.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@preact/signals": "^1.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.24.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": { "optional": true }
  }
}
