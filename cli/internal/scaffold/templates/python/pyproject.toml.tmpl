[project]
name = "{{.Name}}"
version = "0.1.0"
description = ""
requires-python = ">=3.11"
dependencies = [
    "neutron>={{.NeutronVer}}",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "pytest-asyncio>=0.24",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
