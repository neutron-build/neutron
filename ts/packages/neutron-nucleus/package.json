{
  "name": "@neutron/nucleus",
  "version": "0.1.0",
  "description": "TypeScript client for Nucleus multi-model database engine.",
  "author": "Tyler",
  "type": "module",
  "license": "BUSL-1.1",
  "homepage": "https://neutron.build",
  "repository": {
    "type": "git",
    "url": "https://github.com/neutron-build/neutron",
    "directory": "ts/packages/neutron-nucleus"
  },
  "keywords": [
    "neutron",
    "nucleus",
    "database",
    "multi-model",
    "sql",
    "kv",
    "vector",
    "graph",
    "timeseries"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sql": {
      "types": "./dist/sql/index.d.ts",
      "import": "./dist/sql/index.js"
    },
    "./kv": {
      "types": "./dist/kv/index.d.ts",
      "import": "./dist/kv/index.js"
    },
    "./vector": {
      "types": "./dist/vector/index.d.ts",
      "import": "./dist/vector/index.js"
    },
    "./document": {
      "types": "./dist/document/index.d.ts",
      "import": "./dist/document/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./fts": {
      "types": "./dist/fts/index.d.ts",
      "import": "./dist/fts/index.js"
    },
    "./geo": {
      "types": "./dist/geo/index.d.ts",
      "import": "./dist/geo/index.js"
    },
    "./blob": {
      "types": "./dist/blob/index.d.ts",
      "import": "./dist/blob/index.js"
    },
    "./timeseries": {
      "types": "./dist/timeseries/index.d.ts",
      "import": "./dist/timeseries/index.js"
    },
    "./streams": {
      "types": "./dist/streams/index.d.ts",
      "import": "./dist/streams/index.js"
    },
    "./columnar": {
      "types": "./dist/columnar/index.d.ts",
      "import": "./dist/columnar/index.js"
    },
    "./datalog": {
      "types": "./dist/datalog/index.d.ts",
      "import": "./dist/datalog/index.js"
    },
    "./cdc": {
      "types": "./dist/cdc/index.d.ts",
      "import": "./dist/cdc/index.js"
    },
    "./pubsub": {
      "types": "./dist/pubsub/index.d.ts",
      "import": "./dist/pubsub/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
