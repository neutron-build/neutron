{
  "name": "neutron-data",
  "version": "0.1.0",
  "description": "Data layer for Neutron. Database (Drizzle), cache, sessions, queues, storage, and rate limiting.",
  "author": "Tyler",
  "license": "BUSL-1.1",
  "homepage": "https://neutron.build",
  "repository": {
    "type": "git",
    "url": "https://github.com/neutron-build/neutron",
    "directory": "packages/neutron-data"
  },
  "keywords": [
    "neutron",
    "data",
    "database",
    "drizzle",
    "cache",
    "session",
    "queue"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit --pretty false",
    "test": "pnpm run build && node --test --experimental-test-isolation=none dist/ratelimit/index.test.js"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@libsql/client": "^0.17.0",
    "bullmq": "^5.58.0",
    "drizzle-orm": "^0.44.5",
    "ioredis": "^5.8.1",
    "postgres": "^3.4.7"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@libsql/client": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.2"
  }
}
