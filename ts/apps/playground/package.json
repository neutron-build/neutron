{
  "name": "@neutron/playground",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "neutron dev",
    "build": "neutron build",
    "build:vercel": "neutron build --preset vercel",
    "build:cloudflare": "neutron build --preset cloudflare --cloudflare-mode workers",
    "build:docker": "neutron build --preset docker",
    "start": "neutron start",
    "preview": "neutron preview",
    "worker": "neutron worker",
    "db:generate": "drizzle-kit generate --config drizzle.config.mjs",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.mjs",
    "db:seed": "node ./scripts/seed.mjs",
    "deploy-check:vercel": "neutron deploy-check --preset vercel",
    "deploy-check:cloudflare": "neutron deploy-check --preset cloudflare",
    "deploy-check:docker": "neutron deploy-check --preset docker"
  },
  "dependencies": {
    "neutron": "workspace:*",
    "neutron-cli": "workspace:*",
    "neutron-data": "workspace:*",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.4",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
