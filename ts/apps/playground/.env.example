# Default profile is in-memory. Set this to enable production-style drivers.
NEUTRON_DATA_PROFILE=production

# Database profile:
# - if DATABASE_URL exists -> postgres
# - otherwise -> sqlite via SQLITE_PATH (optional, defaults to .neutron/dev.db)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/neutron
SQLITE_PATH=.neutron/dev.db

# Dragonfly / Redis-compatible backend for cache, sessions, and queue
DRAGONFLY_URL=redis://127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379
NEUTRON_QUEUE_NAME=neutron-playground

# Optional S3-compatible storage
# S3_BUCKET=neutron-assets
# S3_REGION=auto
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_FORCE_PATH_STYLE=1
